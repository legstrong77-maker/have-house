# ============================================================
# Have-House 環境設定範例
# 複製成 .env 後修改密碼即可
# ============================================================

# 資料庫
POSTGRES_DB=havehouse
POSTGRES_USER=havehouse
POSTGRES_PASSWORD=please-change-this-password
DB_PORT=5432

# API
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Web
WEB_PORT=8080
VITE_API_BASE=/api

# ETL
# 啟動 scheduler 時是否立刻先跑一次（首次部署設 true 補歷史資料）
RUN_ON_START=false
